# Copy this file to .env.local and fill in your project credentials.
# Never commit the real .env.local — it is already ignored by .gitignore.
#
# Find these values in your Supabase project dashboard:
# Project Settings -> API -> Project URL / Project API keys (anon/public key).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Find this in the Clerk dashboard: dashboard.clerk.com -> API Keys.
# This app authenticates admins via Clerk, configured as a Supabase
# Third-Party Auth provider (see supabase/README.md) — NOT Supabase's own
# email/password auth.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Optional: overrides the app name shown in the UI/browser tab.
VITE_APP_NAME=Riply Admin
